bgp4_rfc4271: CONTEXT =
BEGIN

  % Executable finite-state abstraction of RFC 4271, "A Border Gateway
  % Protocol 4 (BGP-4)".  The model covers BGP message formats, OPEN
  % negotiation, UPDATE/path-attribute processing, NOTIFICATION/error
  % handling, the peer finite-state machine, route selection and
  % advertisement, timers, and the TCP MD5 security support requirement.
  %
  % Abstractions:
  % - Concrete IPv4 prefixes, byte encodings, AS_PATH segments, timers, TCP
  %   streams, and policy databases are represented by finite predicates.
  % - One abstract peer session and one abstract NLRI equivalence class are
  %   enough to model the local safety obligations in RFC 4271.
  % - Route preference and tie-breaking are represented by boolean facts that
  %   record whether the prescribed checks have been applied.

  BgpState: TYPE = {idle, connect, active, opensent, openconfirm, established};
  PeerKind: TYPE = {peer_ibgp, peer_ebgp};
  MessageType: TYPE = {msg_open, msg_update, msg_notification, msg_keepalive, msg_route_refresh, msg_unknown};

  ErrorCode: TYPE = {
    err_none,
    err_message_header,
    err_open_message,
    err_update_message,
    err_hold_timer_expired,
    err_fsm,
    err_cease
  };

  ErrorSubcode: TYPE = {
    sub_none,
    sub_connection_not_synchronized,
    sub_bad_message_length,
    sub_bad_message_type,
    sub_unsupported_version_number,
    sub_bad_peer_as,
    sub_bad_bgp_identifier,
    sub_unsupported_optional_parameter,
    sub_unacceptable_hold_time,
    sub_malformed_attribute_list,
    sub_unrecognized_well_known_attribute,
    sub_missing_well_known_attribute,
    sub_attribute_flags_error,
    sub_attribute_length_error,
    sub_invalid_origin_attribute,
    sub_invalid_next_hop_attribute,
    sub_optional_attribute_error,
    sub_invalid_network_field,
    sub_malformed_as_path
  };

  Event: TYPE = {
    ev_idle,
    ev_manual_start,
    ev_passive_start,
    ev_incoming_fsm_instantiated,
    ev_tcp_success,
    ev_open_accepted,
    ev_keepalive_received,
    ev_keepalive_sent,
    ev_update_received,
    ev_update_withdrawn,
    ev_update_replace,
    ev_update_no_nlri_valid,
    ev_route_selected,
    ev_route_unresolvable,
    ev_route_disseminated,
    ev_adj_rib_out_withdrawn,
    ev_update_send,
    ev_header_bad_marker,
    ev_header_bad_length,
    ev_header_bad_type,
    ev_open_bad_version,
    ev_open_bad_peer_as,
    ev_open_bad_hold_time,
    ev_open_bad_bgp_identifier,
    ev_open_unsupported_optional,
    ev_open_malformed_optional,
    ev_update_attr_lengths_too_large,
    ev_update_attr_flags_error,
    ev_update_attr_length_error,
    ev_update_missing_well_known,
    ev_update_unrecognized_well_known,
    ev_update_invalid_origin,
    ev_update_invalid_next_hop,
    ev_update_semantic_next_hop,
    ev_update_malformed_as_path,
    ev_update_optional_attr_error,
    ev_update_duplicate_attr,
    ev_update_invalid_nlri,
    ev_update_semantic_prefix,
    ev_hold_timer_expired,
    ev_fsm_error,
    ev_cease,
    ev_collision_resolved,
    ev_connection_closed,
    ev_notification_received,
    ev_originated_route,
    ev_med_removed,
    ev_aggregate_route,
    ev_timer_jittered,
    ev_security_support_checked,
    ev_version_negotiation_checked
  };

  header_error?(c: ErrorCode): BOOLEAN = c = err_message_header;

  update_syntax_error?(e: Event): BOOLEAN =
    (e = ev_update_attr_lengths_too_large) OR
    (e = ev_update_attr_flags_error) OR
    (e = ev_update_attr_length_error) OR
    (e = ev_update_missing_well_known) OR
    (e = ev_update_unrecognized_well_known) OR
    (e = ev_update_invalid_origin) OR
    (e = ev_update_invalid_next_hop) OR
    (e = ev_update_malformed_as_path) OR
    (e = ev_update_optional_attr_error) OR
    (e = ev_update_duplicate_attr) OR
    (e = ev_update_invalid_nlri);

  non_idle?(s: BgpState): BOOLEAN =
    (s = connect) OR (s = active) OR (s = opensent) OR
    (s = openconfirm) OR (s = established);

  bgp: MODULE =
  BEGIN
    LOCAL state: BgpState
    LOCAL peer_kind: PeerKind
    LOCAL tcp_connected: BOOLEAN
    LOCAL listening_on_tcp_179: BOOLEAN
    LOCAL tcp_port_179_supported: BOOLEAN
    LOCAL resources_allocated: BOOLEAN
    LOCAL connect_retry_timer_running: BOOLEAN
    LOCAL connect_retry_counter_zero: BOOLEAN
    LOCAL hold_timer_running: BOOLEAN
    LOCAL keepalive_timer_running: BOOLEAN
    LOCAL hold_time_zero: BOOLEAN
    LOCAL hold_time_negotiated: BOOLEAN
    LOCAL open_sent: BOOLEAN
    LOCAL keepalive_sent: BOOLEAN
    LOCAL notification_sent: BOOLEAN
    LOCAL connection_closed: BOOLEAN
    LOCAL routes_deleted: BOOLEAN
    LOCAL adj_rib_in_cleared: BOOLEAN
    LOCAL loc_rib_invalidated: BOOLEAN
    LOCAL best_routes_recalculated: BOOLEAN
    LOCAL one_fsm_per_configured_peer: BOOLEAN
    LOCAL one_tcp_connection_per_fsm: BOOLEAN
    LOCAL incoming_fsm_instantiated: BOOLEAN
    LOCAL collision_detected: BOOLEAN
    LOCAL retained_higher_identifier_connection: BOOLEAN

    LOCAL last_event: Event
    LOCAL last_message_type: MessageType
    LOCAL last_error: ErrorCode
    LOCAL last_subcode: ErrorSubcode
    LOCAL last_notification_data_present: BOOLEAN
    LOCAL last_data_contains_erroneous_length: BOOLEAN
    LOCAL last_data_contains_erroneous_type: BOOLEAN
    LOCAL last_data_contains_erroneous_attribute: BOOLEAN
    LOCAL last_data_contains_missing_attr_code: BOOLEAN
    LOCAL last_data_contains_supported_version: BOOLEAN

    LOCAL message_marker_all_ones: BOOLEAN
    LOCAL message_length_min_19: BOOLEAN
    LOCAL message_length_max_4096: BOOLEAN
    LOCAL message_length_smallest_required: BOOLEAN
    LOCAL message_type_recognized: BOOLEAN
    LOCAL open_message_first_after_tcp: BOOLEAN
    LOCAL open_version_four: BOOLEAN
    LOCAL open_hold_time_zero_or_ge_three: BOOLEAN
    LOCAL open_hold_time_rejected_one_or_two: BOOLEAN
    LOCAL open_uses_negotiated_hold_time: BOOLEAN
    LOCAL open_bgp_identifier_valid: BOOLEAN
    LOCAL open_peer_as_acceptable: BOOLEAN
    LOCAL optional_parameter_recognized: BOOLEAN
    LOCAL optional_parameter_well_formed: BOOLEAN
    LOCAL keepalive_length_19: BOOLEAN
    LOCAL keepalive_not_more_frequent_than_one_per_second: BOOLEAN
    LOCAL periodic_keepalive_suppressed_for_zero_hold: BOOLEAN
    LOCAL notification_length_min_21: BOOLEAN
    LOCAL notification_closes_connection_immediately: BOOLEAN

    LOCAL update_received_in_established: BOOLEAN
    LOCAL update_has_nlri: BOOLEAN
    LOCAL update_has_withdrawn: BOOLEAN
    LOCAL update_has_single_path_attribute_set: BOOLEAN
    LOCAL path_attrs_apply_to_all_nlri: BOOLEAN
    LOCAL duplicate_prefix_processed_as_withdraw_ignored: BOOLEAN
    LOCAL correct_attrs_no_nlri_valid: BOOLEAN
    LOCAL adj_rib_in_has_route: BOOLEAN
    LOCAL loc_rib_has_route: BOOLEAN
    LOCAL adj_rib_out_has_route: BOOLEAN
    LOCAL routing_table_has_route: BOOLEAN
    LOCAL withdrawn_removed_from_adj_rib_in: BOOLEAN
    LOCAL replacement_replaces_older_route: BOOLEAN
    LOCAL decision_process_run: BOOLEAN
    LOCAL phase1_done: BOOLEAN
    LOCAL phase2_done: BOOLEAN
    LOCAL phase3_done: BOOLEAN
    LOCAL route_feasible: BOOLEAN
    LOCAL route_unfeasible: BOOLEAN
    LOCAL route_eligible: BOOLEAN
    LOCAL route_ineligible: BOOLEAN
    LOCAL route_selected_highest_preference: BOOLEAN
    LOCAL preference_independent_of_other_routes: BOOLEAN
    LOCAL next_hop_resolvable: BOOLEAN
    LOCAL would_be_unresolvable_if_installed: BOOLEAN
    LOCAL as_loop_detected: BOOLEAN
    LOCAL immediate_next_hop_determined: BOOLEAN
    LOCAL forwarding_next_hop_resolved: BOOLEAN
    LOCAL unresolvable_route_removed_from_loc_rib: BOOLEAN
    LOCAL unresolvable_route_kept_in_adj_rib_in: BOOLEAN
    LOCAL tie_break_order_applied: BOOLEAN
    LOCAL policy_allows_adj_rib_out: BOOLEAN
    LOCAL route_advertised: BOOLEAN
    LOCAL advertised_route_used_by_speaker: BOOLEAN
    LOCAL internal_route_redistributed_to_internal: BOOLEAN
    LOCAL replacement_absent: BOOLEAN
    LOCAL update_sent_for_unfeasible: BOOLEAN
    LOCAL no_reachable_route_advertised: BOOLEAN
    LOCAL min_route_advertisement_interval_respected: BOOLEAN
    LOCAL route_too_large_not_advertised: BOOLEAN

    LOCAL well_known_attrs_recognized: BOOLEAN
    LOCAL mandatory_attrs_present: BOOLEAN
    LOCAL origin_present: BOOLEAN
    LOCAL as_path_present: BOOLEAN
    LOCAL next_hop_present: BOOLEAN
    LOCAL well_known_transitive_bit_set: BOOLEAN
    LOCAL partial_bit_legal: BOOLEAN
    LOCAL lower_flag_bits_zero_when_sent: BOOLEAN
    LOCAL lower_flag_bits_ignored_when_received: BOOLEAN
    LOCAL well_known_attrs_passed: BOOLEAN
    LOCAL unknown_transitive_accepted: BOOLEAN
    LOCAL unknown_transitive_passed: BOOLEAN
    LOCAL partial_bit_set: BOOLEAN
    LOCAL recognized_transitive_partial_preserved: BOOLEAN
    LOCAL unknown_nontransitive_ignored: BOOLEAN
    LOCAL unknown_nontransitive_passed: BOOLEAN
    LOCAL out_of_order_attrs_handled: BOOLEAN
    LOCAL origin_value_valid: BOOLEAN
    LOCAL as_path_syntax_ok: BOOLEAN
    LOCAL next_hop_syntax_ok: BOOLEAN
    LOCAL next_hop_semantics_ok: BOOLEAN
    LOCAL local_pref_included_to_internal: BOOLEAN
    LOCAL local_pref_sent_to_external: BOOLEAN
    LOCAL local_pref_ignored_from_external: BOOLEAN
    LOCAL higher_local_pref_preferred: BOOLEAN
    LOCAL as_path_modified_for_internal: BOOLEAN
    LOCAL as_path_prepended_for_external: BOOLEAN
    LOCAL originated_ebgp_as_path_has_own_as: BOOLEAN
    LOCAL originated_ibgp_as_path_empty: BOOLEAN
    LOCAL third_party_next_hop_disable_supported: BOOLEAN
    LOCAL originated_route_uses_peer_next_hop: BOOLEAN
    LOCAL installed_route_uses_self_next_hop: BOOLEAN
    LOCAL med_propagated_to_other_neighboring_as: BOOLEAN
    LOCAL med_removal_supported: BOOLEAN
    LOCAL med_removed_before_decision: BOOLEAN
    LOCAL med_altered_before_decision: BOOLEAN
    LOCAL atomic_aggregate_present: BOOLEAN
    LOCAL atomic_aggregate_removed: BOOLEAN
    LOCAL atomic_more_specific_made: BOOLEAN
    LOCAL aggregator_has_own_as_and_address: BOOLEAN

    LOCAL semantic_error_logged: BOOLEAN
    LOCAL route_ignored: BOOLEAN
    LOCAL prefix_ignored: BOOLEAN
    LOCAL optional_attr_discarded: BOOLEAN
    LOCAL fatal_error_present: BOOLEAN

    LOCAL overlapping_routes_considered: BOOLEAN
    LOCAL overlapping_routes_same_next_hop: BOOLEAN
    LOCAL overlapping_routes_installed_or_aggregated: BOOLEAN
    LOCAL different_med_routes_aggregated: BOOLEAN
    LOCAL atomic_aggregate_carried_into_aggregate: BOOLEAN
    LOCAL input_aggregator_attrs_carried: BOOLEAN

    LOCAL hold_timer_configurable_per_peer: BOOLEAN
    LOCAL jitter_applied_to_relevant_timers: BOOLEAN
    LOCAL jitter_default_factor_075_to_100: BOOLEAN
    LOCAL new_random_each_timer_set: BOOLEAN
    LOCAL tcp_md5_supported: BOOLEAN
    LOCAL tcp_md5_per_peer_activatable: BOOLEAN
    LOCAL future_versions_retain_open_notification_format: BOOLEAN

    INITIALIZATION
      state = idle;
      peer_kind = peer_ebgp;
      tcp_connected = FALSE;
      listening_on_tcp_179 = FALSE;
      tcp_port_179_supported = TRUE;
      resources_allocated = FALSE;
      connect_retry_timer_running = FALSE;
      connect_retry_counter_zero = TRUE;
      hold_timer_running = FALSE;
      keepalive_timer_running = FALSE;
      hold_time_zero = FALSE;
      hold_time_negotiated = FALSE;
      open_sent = FALSE;
      keepalive_sent = FALSE;
      notification_sent = FALSE;
      connection_closed = FALSE;
      routes_deleted = FALSE;
      adj_rib_in_cleared = FALSE;
      loc_rib_invalidated = FALSE;
      best_routes_recalculated = FALSE;
      one_fsm_per_configured_peer = TRUE;
      one_tcp_connection_per_fsm = TRUE;
      incoming_fsm_instantiated = FALSE;
      collision_detected = FALSE;
      retained_higher_identifier_connection = FALSE;
      last_event = ev_idle;
      last_message_type = msg_unknown;
      last_error = err_none;
      last_subcode = sub_none;
      last_notification_data_present = FALSE;
      last_data_contains_erroneous_length = FALSE;
      last_data_contains_erroneous_type = FALSE;
      last_data_contains_erroneous_attribute = FALSE;
      last_data_contains_missing_attr_code = FALSE;
      last_data_contains_supported_version = FALSE;
      message_marker_all_ones = TRUE;
      message_length_min_19 = TRUE;
      message_length_max_4096 = TRUE;
      message_length_smallest_required = TRUE;
      message_type_recognized = TRUE;
      open_message_first_after_tcp = FALSE;
      open_version_four = TRUE;
      open_hold_time_zero_or_ge_three = TRUE;
      open_hold_time_rejected_one_or_two = FALSE;
      open_uses_negotiated_hold_time = FALSE;
      open_bgp_identifier_valid = TRUE;
      open_peer_as_acceptable = TRUE;
      optional_parameter_recognized = TRUE;
      optional_parameter_well_formed = TRUE;
      keepalive_length_19 = TRUE;
      keepalive_not_more_frequent_than_one_per_second = TRUE;
      periodic_keepalive_suppressed_for_zero_hold = FALSE;
      notification_length_min_21 = TRUE;
      notification_closes_connection_immediately = FALSE;
      update_received_in_established = FALSE;
      update_has_nlri = FALSE;
      update_has_withdrawn = FALSE;
      update_has_single_path_attribute_set = TRUE;
      path_attrs_apply_to_all_nlri = TRUE;
      duplicate_prefix_processed_as_withdraw_ignored = TRUE;
      correct_attrs_no_nlri_valid = FALSE;
      adj_rib_in_has_route = FALSE;
      loc_rib_has_route = FALSE;
      adj_rib_out_has_route = FALSE;
      routing_table_has_route = FALSE;
      withdrawn_removed_from_adj_rib_in = FALSE;
      replacement_replaces_older_route = FALSE;
      decision_process_run = FALSE;
      phase1_done = FALSE;
      phase2_done = FALSE;
      phase3_done = FALSE;
      route_feasible = FALSE;
      route_unfeasible = FALSE;
      route_eligible = FALSE;
      route_ineligible = FALSE;
      route_selected_highest_preference = FALSE;
      preference_independent_of_other_routes = TRUE;
      next_hop_resolvable = TRUE;
      would_be_unresolvable_if_installed = FALSE;
      as_loop_detected = FALSE;
      immediate_next_hop_determined = FALSE;
      forwarding_next_hop_resolved = FALSE;
      unresolvable_route_removed_from_loc_rib = FALSE;
      unresolvable_route_kept_in_adj_rib_in = FALSE;
      tie_break_order_applied = FALSE;
      policy_allows_adj_rib_out = TRUE;
      route_advertised = FALSE;
      advertised_route_used_by_speaker = FALSE;
      internal_route_redistributed_to_internal = FALSE;
      replacement_absent = FALSE;
      update_sent_for_unfeasible = FALSE;
      no_reachable_route_advertised = FALSE;
      min_route_advertisement_interval_respected = TRUE;
      route_too_large_not_advertised = FALSE;
      well_known_attrs_recognized = TRUE;
      mandatory_attrs_present = TRUE;
      origin_present = TRUE;
      as_path_present = TRUE;
      next_hop_present = TRUE;
      well_known_transitive_bit_set = TRUE;
      partial_bit_legal = TRUE;
      lower_flag_bits_zero_when_sent = TRUE;
      lower_flag_bits_ignored_when_received = TRUE;
      well_known_attrs_passed = TRUE;
      unknown_transitive_accepted = TRUE;
      unknown_transitive_passed = TRUE;
      partial_bit_set = TRUE;
      recognized_transitive_partial_preserved = TRUE;
      unknown_nontransitive_ignored = TRUE;
      unknown_nontransitive_passed = FALSE;
      out_of_order_attrs_handled = TRUE;
      origin_value_valid = TRUE;
      as_path_syntax_ok = TRUE;
      next_hop_syntax_ok = TRUE;
      next_hop_semantics_ok = TRUE;
      local_pref_included_to_internal = TRUE;
      local_pref_sent_to_external = FALSE;
      local_pref_ignored_from_external = TRUE;
      higher_local_pref_preferred = TRUE;
      as_path_modified_for_internal = FALSE;
      as_path_prepended_for_external = TRUE;
      originated_ebgp_as_path_has_own_as = TRUE;
      originated_ibgp_as_path_empty = TRUE;
      third_party_next_hop_disable_supported = TRUE;
      originated_route_uses_peer_next_hop = FALSE;
      installed_route_uses_self_next_hop = FALSE;
      med_propagated_to_other_neighboring_as = FALSE;
      med_removal_supported = TRUE;
      med_removed_before_decision = FALSE;
      med_altered_before_decision = FALSE;
      atomic_aggregate_present = FALSE;
      atomic_aggregate_removed = FALSE;
      atomic_more_specific_made = FALSE;
      aggregator_has_own_as_and_address = TRUE;
      semantic_error_logged = FALSE;
      route_ignored = FALSE;
      prefix_ignored = FALSE;
      optional_attr_discarded = FALSE;
      fatal_error_present = FALSE;
      overlapping_routes_considered = FALSE;
      overlapping_routes_same_next_hop = TRUE;
      overlapping_routes_installed_or_aggregated = FALSE;
      different_med_routes_aggregated = FALSE;
      atomic_aggregate_carried_into_aggregate = FALSE;
      input_aggregator_attrs_carried = FALSE;
      hold_timer_configurable_per_peer = TRUE;
      jitter_applied_to_relevant_timers = FALSE;
      jitter_default_factor_075_to_100 = TRUE;
      new_random_each_timer_set = FALSE;
      tcp_md5_supported = TRUE;
      tcp_md5_per_peer_activatable = TRUE;
      future_versions_retain_open_notification_format = TRUE

    TRANSITION
      [
        manual_start:
          state = idle
          -->
            state' = connect;
            last_event' = ev_manual_start;
            resources_allocated' = TRUE;
            connect_retry_counter_zero' = TRUE;
            connect_retry_timer_running' = TRUE;
            listening_on_tcp_179' = TRUE;
            tcp_port_179_supported' = TRUE;
            connection_closed' = FALSE;
            notification_sent' = FALSE

      []
        passive_start:
          state = idle
          -->
            state' = active;
            last_event' = ev_passive_start;
            resources_allocated' = TRUE;
            connect_retry_counter_zero' = TRUE;
            connect_retry_timer_running' = TRUE;
            listening_on_tcp_179' = TRUE;
            tcp_port_179_supported' = TRUE;
            connection_closed' = FALSE;
            notification_sent' = FALSE

      []
        tcp_success_sends_open:
          (state = connect OR state = active)
          -->
            state' = opensent;
            last_event' = ev_tcp_success;
            tcp_connected' = TRUE;
            resources_allocated' = TRUE;
            connect_retry_timer_running' = FALSE;
            open_sent' = TRUE;
            open_message_first_after_tcp' = TRUE;
            hold_timer_running' = TRUE;
            hold_time_zero' = FALSE;
            last_message_type' = msg_open;
            message_marker_all_ones' = TRUE;
            message_length_min_19' = TRUE;
            message_length_max_4096' = TRUE;
            message_length_smallest_required' = TRUE;
            message_type_recognized' = TRUE

      []
        open_accepted:
          state = opensent
          -->
            state' = openconfirm;
            last_event' = ev_open_accepted;
            tcp_connected' = TRUE;
            resources_allocated' = TRUE;
            keepalive_sent' = TRUE;
            last_message_type' = msg_keepalive;
            hold_time_zero' = FALSE;
            hold_time_negotiated' = TRUE;
            open_version_four' = TRUE;
            open_hold_time_zero_or_ge_three' = TRUE;
            open_uses_negotiated_hold_time' = TRUE;
            open_bgp_identifier_valid' = TRUE;
            open_peer_as_acceptable' = TRUE;
            message_marker_all_ones' = TRUE;
            message_length_min_19' = TRUE;
            message_length_max_4096' = TRUE;
            message_length_smallest_required' = TRUE;
            message_type_recognized' = TRUE;
            keepalive_length_19' = TRUE;
            keepalive_timer_running' = TRUE;
            hold_timer_running' = TRUE;
            peer_kind' IN {peer_ibgp, peer_ebgp}

      []
        keepalive_confirms_open:
          state = openconfirm
          -->
            state' = established;
            last_event' = ev_keepalive_received;
            tcp_connected' = TRUE;
            resources_allocated' = TRUE;
            hold_timer_running' = TRUE;
            last_message_type' = msg_keepalive

      []
        established_keepalive_sent:
          state = established AND NOT hold_time_zero
          -->
            state' = established;
            last_event' = ev_keepalive_sent;
            tcp_connected' = TRUE;
            resources_allocated' = TRUE;
            keepalive_sent' = TRUE;
            keepalive_length_19' = TRUE;
            keepalive_not_more_frequent_than_one_per_second' = TRUE;
            message_marker_all_ones' = TRUE;
            message_length_min_19' = TRUE;
            message_length_max_4096' = TRUE;
            message_length_smallest_required' = TRUE;
            message_type_recognized' = TRUE;
            keepalive_timer_running' = TRUE;
            hold_timer_running' = TRUE;
            last_message_type' = msg_keepalive

      []
        zero_hold_suppresses_periodic_keepalive:
          state = established
          -->
            state' = established;
            last_event' = ev_keepalive_sent;
            tcp_connected' = TRUE;
            resources_allocated' = TRUE;
            hold_time_zero' = TRUE;
            keepalive_sent' = FALSE;
            periodic_keepalive_suppressed_for_zero_hold' = TRUE;
            keepalive_timer_running' = FALSE;
            hold_timer_running' = FALSE;
            last_message_type' = msg_keepalive

      []
        receive_valid_update:
          state = established
          -->
            state' = established;
            last_event' = ev_update_received;
            last_message_type' = msg_update;
            tcp_connected' = TRUE;
            resources_allocated' = TRUE;
            update_received_in_established' = TRUE;
            update_has_nlri' = TRUE;
            update_has_withdrawn' = FALSE;
            message_marker_all_ones' = TRUE;
            message_length_min_19' = TRUE;
            message_length_max_4096' = TRUE;
            message_length_smallest_required' = TRUE;
            message_type_recognized' = TRUE;
            update_has_single_path_attribute_set' = TRUE;
            path_attrs_apply_to_all_nlri' = TRUE;
            well_known_attrs_recognized' = TRUE;
            mandatory_attrs_present' = TRUE;
            origin_present' = TRUE;
            as_path_present' = TRUE;
            next_hop_present' = TRUE;
            adj_rib_in_has_route' = TRUE;
            route_feasible' = TRUE;
            route_unfeasible' = FALSE;
            decision_process_run' = TRUE;
            phase1_done' = TRUE;
            preference_independent_of_other_routes' = TRUE;
            hold_timer_running' = NOT hold_time_zero

      []
        receive_withdrawn_update:
          state = established
          -->
            state' = established;
            last_event' = ev_update_withdrawn;
            last_message_type' = msg_update;
            tcp_connected' = TRUE;
            resources_allocated' = TRUE;
            update_received_in_established' = TRUE;
            update_has_withdrawn' = TRUE;
            update_has_nlri' = FALSE;
            adj_rib_in_has_route' = FALSE;
            withdrawn_removed_from_adj_rib_in' = TRUE;
            route_unfeasible' = TRUE;
            decision_process_run' = TRUE;
            phase1_done' = TRUE;
            hold_timer_running' = NOT hold_time_zero

      []
        receive_replacement_update:
          state = established
          -->
            state' = established;
            last_event' = ev_update_replace;
