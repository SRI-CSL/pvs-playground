  END;

  % RFC 4271 Section 3, source lines 419-424: BGP uses TCP and listens on
  % TCP port 179.
  req_s3_tcp_port_179_supported: THEOREM bgp
    |- G(tcp_port_179_supported);

  req_s3_connection_errors_notify_and_close: THEOREM bgp
    |- G((last_event = ev_header_bad_marker OR
          last_event = ev_header_bad_length OR
          last_event = ev_header_bad_type OR
          last_event = ev_open_bad_version OR
          last_event = ev_update_invalid_nlri)
         => (notification_sent AND connection_closed));

  % RFC 4271 Sections 3.1-3.2, source lines 500-552: routes are advertised
  % in UPDATEs; withdrawals and replacement routes update Adj-RIB-In, Loc-RIB
  % contains selected routes, and each Loc-RIB next-hop is resolvable.
  req_s3_1_withdraw_removes_adj_rib_in: THEOREM bgp
    |- G((last_event = ev_update_withdrawn) =>
         (withdrawn_removed_from_adj_rib_in AND NOT adj_rib_in_has_route));

  req_s3_1_replacement_replaces_older_route: THEOREM bgp
    |- G((last_event = ev_update_replace) =>
         (replacement_replaces_older_route AND adj_rib_in_has_route));

  req_s3_2_loc_rib_next_hop_resolvable: THEOREM bgp
    |- G(loc_rib_has_route => next_hop_resolvable);

  req_s3_2_adj_rib_out_advertised_by_update: THEOREM bgp
    |- G(adj_rib_out_has_route => route_advertised);

  % RFC 4271 Sections 4 and 4.1, source lines 590-656: message size limits,
  % fixed marker, length bounds, and recognized message types.
  req_s4_max_message_size_supported: THEOREM bgp
    |- G(message_length_max_4096);

  req_s4_min_message_size_19: THEOREM bgp
    |- G((last_event = ev_tcp_success OR
          last_event = ev_open_accepted OR
          (last_event = ev_keepalive_sent AND keepalive_sent) OR
          last_event = ev_update_received OR
          last_event = ev_update_send)
         => message_length_min_19);

  req_s4_1_marker_all_ones_when_valid: THEOREM bgp
    |- G((last_event = ev_tcp_success OR
          last_event = ev_open_accepted OR
          last_event = ev_update_received)
         => message_marker_all_ones);

  req_s4_1_length_valid_when_not_error: THEOREM bgp
    |- G((last_event = ev_tcp_success OR
          last_event = ev_open_accepted OR
          (last_event = ev_keepalive_sent AND keepalive_sent) OR
          last_event = ev_update_received OR
          last_event = ev_update_send)
         =>
         (message_length_min_19 AND message_length_max_4096 AND
          message_length_smallest_required));

  req_s4_1_type_recognized_when_not_error: THEOREM bgp
    |- G((last_event = ev_tcp_success OR
          last_event = ev_open_accepted OR
          (last_event = ev_keepalive_sent AND keepalive_sent) OR
          last_event = ev_update_received OR
          last_event = ev_update_send)
         => message_type_recognized);

  % RFC 4271 Sections 4.2-4.5, source lines 679-1274: OPEN version and hold
  % time negotiation, KEEPALIVE limits, and NOTIFICATION close semantics.
  req_s4_2_tcp_success_sends_open_first: THEOREM bgp
    |- G((last_event = ev_tcp_success) =>
         (last_message_type = msg_open AND open_sent AND open_message_first_after_tcp));

  req_s4_2_open_version_four: THEOREM bgp
    |- G((last_event = ev_open_accepted) => open_version_four);

  req_s4_2_hold_time_zero_or_at_least_three: THEOREM bgp
    |- G((last_event = ev_open_accepted) =>
         (open_hold_time_zero_or_ge_three AND open_uses_negotiated_hold_time));

  req_s4_2_hold_time_one_or_two_rejected: THEOREM bgp
    |- G((last_event = ev_open_bad_hold_time) => open_hold_time_rejected_one_or_two);

  req_s4_4_keepalive_rate_limited: THEOREM bgp
    |- G((last_event = ev_keepalive_sent AND keepalive_sent) =>
         keepalive_not_more_frequent_than_one_per_second);

  req_s4_4_zero_hold_suppresses_periodic_keepalive: THEOREM bgp
    |- G((last_event = ev_keepalive_sent AND hold_time_zero) =>
         periodic_keepalive_suppressed_for_zero_hold AND NOT keepalive_sent);

  req_s4_4_keepalive_length_19: THEOREM bgp
    |- G((last_event = ev_keepalive_sent AND keepalive_sent) => keepalive_length_19);

  req_s4_5_notification_closes_connection: THEOREM bgp
    |- G(notification_sent =>
         (connection_closed OR last_event = ev_update_semantic_next_hop OR
          last_event = ev_update_semantic_prefix));

  req_s4_5_notification_min_length: THEOREM bgp
    |- G(notification_length_min_21);

  % RFC 4271 Sections 5 and 5.1, source lines 1277-1651: well-known and
  % optional path attributes, AS_PATH, NEXT_HOP, MED, LOCAL_PREF,
  % ATOMIC_AGGREGATE, and AGGREGATOR obligations.
  req_s5_well_known_attributes_recognized: THEOREM bgp
    |- G((last_event = ev_update_received) => well_known_attrs_recognized);

  req_s5_mandatory_attrs_present_with_nlri: THEOREM bgp
    |- G((last_event = ev_update_received AND update_has_nlri) =>
         (mandatory_attrs_present AND origin_present AND as_path_present AND next_hop_present));

  req_s5_well_known_attrs_passed: THEOREM bgp
    |- G(well_known_attrs_passed);

  req_s5_unrecognized_transitive_passed_partial: THEOREM bgp
    |- G(unknown_transitive_accepted =>
         (unknown_transitive_passed AND partial_bit_set));

  req_s5_partial_bit_preserved: THEOREM bgp
    |- G(recognized_transitive_partial_preserved);

  req_s5_unrecognized_nontransitive_ignored: THEOREM bgp
    |- G(unknown_nontransitive_ignored AND NOT unknown_nontransitive_passed);

  req_s5_out_of_order_attrs_handled: THEOREM bgp
    |- G(out_of_order_attrs_handled);

  req_s5_attr_flags_constraints: THEOREM bgp
    |- G(well_known_transitive_bit_set AND partial_bit_legal AND
         lower_flag_bits_zero_when_sent AND lower_flag_bits_ignored_when_received);

  req_s5_1_2_as_path_internal_not_modified: THEOREM bgp
    |- G(NOT as_path_modified_for_internal);

  req_s5_1_2_as_path_external_prepended: THEOREM bgp
    |- G(as_path_prepended_for_external);

  req_s5_1_2_originated_as_path_rules: THEOREM bgp
    |- G((last_event = ev_originated_route) =>
         (originated_ebgp_as_path_has_own_as AND originated_ibgp_as_path_empty));

  req_s5_1_3_next_hop_disable_third_party_supported: THEOREM bgp
    |- G(third_party_next_hop_disable_supported);

  req_s5_1_3_no_peer_or_self_next_hop: THEOREM bgp
    |- G((last_event = ev_originated_route) =>
         (NOT originated_route_uses_peer_next_hop AND NOT installed_route_uses_self_next_hop));

  req_s5_1_4_med_not_propagated_to_other_neighbor_as: THEOREM bgp
    |- G(NOT med_propagated_to_other_neighboring_as);

  req_s5_1_4_med_removal_supported: THEOREM bgp
    |- G(med_removal_supported);

  req_s5_1_4_med_changed_before_decision: THEOREM bgp
    |- G((last_event = ev_med_removed) =>
         (med_removed_before_decision AND med_altered_before_decision));

  req_s5_1_5_local_pref_internal_only: THEOREM bgp
    |- G(local_pref_included_to_internal AND NOT local_pref_sent_to_external);

  req_s5_1_5_external_local_pref_ignored: THEOREM bgp
    |- G(local_pref_ignored_from_external);

  req_s5_1_5_higher_local_pref_preferred: THEOREM bgp
    |- G(higher_local_pref_preferred);

  req_s5_1_6_atomic_not_removed_or_deaggregated: THEOREM bgp
    |- G(atomic_aggregate_present =>
         (NOT atomic_aggregate_removed AND NOT atomic_more_specific_made));

  req_s5_1_7_aggregator_contains_own_as_address: THEOREM bgp
    |- G(aggregator_has_own_as_and_address);

  % RFC 4271 Sections 6.1-6.8, source lines 1653-1997: errors produce the
  % specified NOTIFICATION code/subcode/data and close behavior, with explicit
  % exceptions for semantic NEXT_HOP/prefix errors.
  req_s6_error_closes_and_clears_connection: THEOREM bgp
    |- G((last_event = ev_header_bad_marker OR
          last_event = ev_header_bad_length OR
          last_event = ev_header_bad_type OR
          last_event = ev_open_bad_version OR
          last_event = ev_open_bad_peer_as OR
          last_event = ev_open_bad_hold_time OR
          last_event = ev_open_bad_bgp_identifier OR
          last_event = ev_open_unsupported_optional OR
          last_event = ev_open_malformed_optional OR
          update_syntax_error?(last_event) OR
          last_event = ev_hold_timer_expired OR
          last_event = ev_fsm_error OR
          last_event = ev_cease OR
          last_event = ev_collision_resolved)
         =>
         (NOT tcp_connected AND NOT resources_allocated));

  req_s6_close_clears_ribs_and_recalculates: THEOREM bgp
    |- G(connection_closed =>
         (adj_rib_in_cleared OR last_event = ev_cease OR last_event = ev_fsm_error) AND
         (loc_rib_invalidated OR last_event = ev_cease OR last_event = ev_fsm_error) AND
         (best_routes_recalculated OR last_event = ev_cease OR last_event = ev_fsm_error));

  req_s6_1_header_errors_use_header_code: THEOREM bgp
    |- G((last_event = ev_header_bad_marker OR
          last_event = ev_header_bad_length OR
          last_event = ev_header_bad_type)
         => last_error = err_message_header);

  req_s6_1_bad_marker_subcode: THEOREM bgp
    |- G((last_event = ev_header_bad_marker) =>
         last_subcode = sub_connection_not_synchronized);

  req_s6_1_bad_length_data: THEOREM bgp
    |- G((last_event = ev_header_bad_length) =>
         (last_subcode = sub_bad_message_length AND last_data_contains_erroneous_length));

  req_s6_1_bad_type_data: THEOREM bgp
    |- G((last_event = ev_header_bad_type) =>
         (last_subcode = sub_bad_message_type AND last_data_contains_erroneous_type));

  req_s6_2_open_errors_use_open_code: THEOREM bgp
    |- G((last_event = ev_open_bad_version OR
          last_event = ev_open_bad_peer_as OR
          last_event = ev_open_bad_hold_time OR
          last_event = ev_open_bad_bgp_identifier OR
          last_event = ev_open_unsupported_optional OR
          last_event = ev_open_malformed_optional)
         => last_error = err_open_message);

  req_s6_2_bad_version_data: THEOREM bgp
    |- G((last_event = ev_open_bad_version) =>
         (last_subcode = sub_unsupported_version_number AND
          last_data_contains_supported_version));

  req_s6_2_bad_peer_as_subcode: THEOREM bgp
    |- G((last_event = ev_open_bad_peer_as) => last_subcode = sub_bad_peer_as);

  req_s6_2_bad_hold_time_subcode: THEOREM bgp
    |- G((last_event = ev_open_bad_hold_time) =>
         last_subcode = sub_unacceptable_hold_time);

  req_s6_2_bad_identifier_subcode: THEOREM bgp
    |- G((last_event = ev_open_bad_bgp_identifier) =>
         last_subcode = sub_bad_bgp_identifier);

  req_s6_2_optional_errors: THEOREM bgp
    |- G(((last_event = ev_open_unsupported_optional) =>
          last_subcode = sub_unsupported_optional_parameter) AND
         ((last_event = ev_open_malformed_optional) =>
          last_subcode = sub_none));

  req_s6_3_update_syntax_errors_use_update_code: THEOREM bgp
    |- G(update_syntax_error?(last_event) => last_error = err_update_message);

  req_s6_3_attr_lengths_too_large_malformed_list: THEOREM bgp
    |- G((last_event = ev_update_attr_lengths_too_large) =>
         last_subcode = sub_malformed_attribute_list);

  req_s6_3_attr_flags_error_data: THEOREM bgp
    |- G((last_event = ev_update_attr_flags_error) =>
         (last_subcode = sub_attribute_flags_error AND
          last_data_contains_erroneous_attribute));

  req_s6_3_attr_length_error_data: THEOREM bgp
    |- G((last_event = ev_update_attr_length_error) =>
         (last_subcode = sub_attribute_length_error AND
          last_data_contains_erroneous_attribute));

  req_s6_3_missing_well_known_data: THEOREM bgp
    |- G((last_event = ev_update_missing_well_known) =>
         (last_subcode = sub_missing_well_known_attribute AND
          last_data_contains_missing_attr_code));

  req_s6_3_unrecognized_well_known_data: THEOREM bgp
    |- G((last_event = ev_update_unrecognized_well_known) =>
         (last_subcode = sub_unrecognized_well_known_attribute AND
          last_data_contains_erroneous_attribute));

  req_s6_3_invalid_origin_data: THEOREM bgp
    |- G((last_event = ev_update_invalid_origin) =>
         (last_subcode = sub_invalid_origin_attribute AND
          last_data_contains_erroneous_attribute));

  req_s6_3_invalid_next_hop_syntax_data: THEOREM bgp
    |- G((last_event = ev_update_invalid_next_hop) =>
         (last_subcode = sub_invalid_next_hop_attribute AND
          last_data_contains_erroneous_attribute));

  req_s6_3_semantic_next_hop_no_close: THEOREM bgp
    |- G((last_event = ev_update_semantic_next_hop) =>
         (semantic_error_logged AND route_ignored AND
          NOT notification_sent AND NOT connection_closed));

  req_s6_3_malformed_as_path: THEOREM bgp
    |- G((last_event = ev_update_malformed_as_path) =>
         last_subcode = sub_malformed_as_path);

  req_s6_3_optional_attr_error_discards: THEOREM bgp
    |- G((last_event = ev_update_optional_attr_error) =>
         (optional_attr_discarded AND
          last_subcode = sub_optional_attribute_error AND
          last_data_contains_erroneous_attribute));

  req_s6_3_duplicate_attr_malformed_list: THEOREM bgp
    |- G((last_event = ev_update_duplicate_attr) =>
         last_subcode = sub_malformed_attribute_list);

  req_s6_3_invalid_nlri_subcode: THEOREM bgp
    |- G((last_event = ev_update_invalid_nlri) =>
         last_subcode = sub_invalid_network_field);

  req_s6_3_semantic_prefix_logged_ignored: THEOREM bgp
    |- G((last_event = ev_update_semantic_prefix) =>
         (semantic_error_logged AND prefix_ignored AND
          NOT notification_sent AND NOT connection_closed));

  req_s6_3_correct_attrs_no_nlri_valid: THEOREM bgp
    |- G((last_event = ev_update_no_nlri_valid) =>
         (correct_attrs_no_nlri_valid AND last_error = err_none));

  req_s6_5_hold_timer_expired_notification: THEOREM bgp
    |- G((last_event = ev_hold_timer_expired) =>
         (last_error = err_hold_timer_expired AND notification_sent AND connection_closed));

  req_s6_6_fsm_error_notification: THEOREM bgp
    |- G((last_event = ev_fsm_error) =>
         (last_error = err_fsm AND notification_sent AND connection_closed));

  req_s6_7_cease_not_for_fatal_errors: THEOREM bgp
    |- G((last_event = ev_cease) =>
         (last_error = err_cease AND notification_sent AND NOT fatal_error_present));

  req_s6_8_collision_closes_one_connection: THEOREM bgp
    |- G((last_event = ev_collision_resolved) =>
         (collision_detected AND retained_higher_identifier_connection AND
          notification_sent AND connection_closed AND last_error = err_cease));

  % RFC 4271 Section 7, source lines 2000-2016: future BGP versions retain
  % OPEN and NOTIFICATION formats for version negotiation.
  req_s7_future_versions_retain_formats: THEOREM bgp
    |- G(future_versions_retain_open_notification_format);

  % RFC 4271 Section 8, source lines 2823-4161: peer FSM structure and state
  % transitions through Idle, Connect/Active, OpenSent, OpenConfirm, and
  % Established.
  req_s8_2_1_separate_fsm_per_peer: THEOREM bgp
    |- G(one_fsm_per_configured_peer AND one_tcp_connection_per_fsm);

  req_s8_2_1_incoming_connection_instantiates_fsm: THEOREM bgp
    |- G((last_event = ev_incoming_fsm_instantiated) =>
         (listening_on_tcp_179 AND incoming_fsm_instantiated));

  req_s8_idle_has_no_connection_resources: THEOREM bgp
    |- G((state = idle AND last_event = ev_idle) =>
         (NOT tcp_connected AND NOT resources_allocated));

  req_s8_manual_start_to_connect: THEOREM bgp
    |- G((last_event = ev_manual_start) =>
         (state = connect AND resources_allocated AND
          connect_retry_counter_zero AND connect_retry_timer_running AND
          listening_on_tcp_179));

  req_s8_passive_start_to_active: THEOREM bgp
    |- G((last_event = ev_passive_start AND resources_allocated) =>
         (state = active AND connect_retry_counter_zero AND
          connect_retry_timer_running AND listening_on_tcp_179));

  req_s8_tcp_success_to_opensent: THEOREM bgp
    |- G((last_event = ev_tcp_success) =>
         (state = opensent AND tcp_connected AND open_sent AND hold_timer_running));

  req_s8_valid_open_to_openconfirm: THEOREM bgp
    |- G((last_event = ev_open_accepted) =>
         (state = openconfirm AND keepalive_sent AND hold_time_negotiated));

  req_s8_keepalive_to_established: THEOREM bgp
    |- G((last_event = ev_keepalive_received) =>
         (state = established AND tcp_connected AND resources_allocated));

  req_s8_established_can_exchange_update_keepalive: THEOREM bgp
    |- G((state = established) => (tcp_connected AND resources_allocated));

  req_s8_established_update_error_to_idle: THEOREM bgp
    |- G(update_syntax_error?(last_event) =>
         (state = idle AND notification_sent AND connection_closed));

  % RFC 4271 Section 9, source lines 4162-4945: UPDATE handling, Decision
  % Process phases, route dissemination, rate limiting, overlapping routes,
  % and aggregation.
  req_s9_update_only_processed_in_established: THEOREM bgp
    |- G((last_event = ev_update_received OR
          last_event = ev_update_withdrawn OR
          last_event = ev_update_replace OR
          last_event = ev_update_no_nlri_valid)
         => update_received_in_established);

  req_s9_update_changes_run_decision: THEOREM bgp
    |- G((last_event = ev_update_received OR
          last_event = ev_update_withdrawn OR
          last_event = ev_update_replace)
         => decision_process_run);

  req_s9_1_phase1_preference_independent: THEOREM bgp
    |- G(preference_independent_of_other_routes);

  req_s9_1_2_unresolvable_excluded: THEOREM bgp
    |- G((last_event = ev_route_unresolvable) =>
         (route_ineligible AND NOT route_eligible));

  req_s9_1_2_as_loop_not_selected: THEOREM bgp
    |- G(as_loop_detected => NOT route_eligible);

  req_s9_1_2_selected_installed_loc_rib: THEOREM bgp
    |- G((last_event = ev_route_selected) =>
         (phase2_done AND loc_rib_has_route AND route_selected_highest_preference));

  req_s9_1_2_immediate_next_hop_determined: THEOREM bgp
    |- G((last_event = ev_route_selected) =>
         (immediate_next_hop_determined AND forwarding_next_hop_resolved));

  req_s9_1_2_unresolvable_removed_from_loc_rib: THEOREM bgp
    |- G((last_event = ev_route_unresolvable) =>
         (unresolvable_route_removed_from_loc_rib AND
          unresolvable_route_kept_in_adj_rib_in));

  req_s9_1_2_2_tie_break_order_applied: THEOREM bgp
    |- G((last_event = ev_route_selected) => tie_break_order_applied);

  req_s9_1_3_adj_rib_out_policy_required: THEOREM bgp
    |- G(adj_rib_out_has_route => policy_allows_adj_rib_out);

  req_s9_1_3_policy_exclusion_withdraws_previous: THEOREM bgp
    |- G((last_event = ev_adj_rib_out_withdrawn) =>
         (NOT adj_rib_out_has_route AND update_sent_for_unfeasible));

  req_s9_1_4_overlapping_routes_considered: THEOREM bgp
    |- G((last_event = ev_aggregate_route) =>
         (overlapping_routes_considered AND overlapping_routes_same_next_hop AND
          overlapping_routes_installed_or_aggregated));

  req_s9_2_internal_route_not_redistributed_internal: THEOREM bgp
    |- G(NOT internal_route_redistributed_to_internal);

  req_s9_2_unfeasible_advertised_if_no_replacement: THEOREM bgp
    |- G((last_event = ev_update_send AND replacement_absent) =>
         update_sent_for_unfeasible);

  req_s9_2_no_reachable_route_not_advertised: THEOREM bgp
    |- G(NOT no_reachable_route_advertised);

  req_s9_2_route_too_large_not_advertised: THEOREM bgp
    |- G((last_event = ev_update_send) => route_too_large_not_advertised);

  req_s9_2_1_min_route_advertisement_interval: THEOREM bgp
    |- G(min_route_advertisement_interval_respected);

  req_s9_2_2_2_different_med_not_aggregated: THEOREM bgp
    |- G(NOT different_med_routes_aggregated);

  req_s9_2_2_2_atomic_carried_into_aggregate: THEOREM bgp
    |- G((last_event = ev_aggregate_route AND atomic_aggregate_present) =>
         atomic_aggregate_carried_into_aggregate);

  req_s9_2_2_2_input_aggregator_not_carried: THEOREM bgp
    |- G(NOT input_aggregator_attrs_carried);

  % RFC 4271 Section 10, source lines 4991-5050: timer configurability and
  % jitter.
  req_s10_hold_timer_configurable_per_peer: THEOREM bgp
    |- G(hold_timer_configurable_per_peer);

  req_s10_jitter_applied_with_default_range: THEOREM bgp
    |- G((last_event = ev_timer_jittered) =>
         (jitter_applied_to_relevant_timers AND
          jitter_default_factor_075_to_100 AND
          new_random_each_timer_set));

  % RFC 4271 Appendix E and Security Considerations, source lines 5262 and
  % 5415-5435: compliant implementations support TCP MD5 and allow per-peer
  % activation.
  req_app_e_tcp_md5_supported: THEOREM bgp
    |- G(tcp_md5_supported);

  req_security_tcp_md5_per_peer_activation: THEOREM bgp
    |- G(tcp_md5_per_peer_activatable);

END
